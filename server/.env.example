# MongoDB Configuration
# For MongoDB Atlas:
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/crm_db?retryWrites=true&w=majority

# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/crm_db

# JWT Secret
JWT_SECRET=your-super-secret-key-change-in-production

# Server Port
API_PORT=3000

# SIM SMS Gateway (optional, for real phone OTP SMS)
# See sms-gateway-android/README.md
SMS_GATEWAY_BASE_URL=http://<phone-ip>:8080
SMS_GATEWAY_BASE_URLS=http://<phone-ip-1>:8080,http://<phone-ip-2>:8080
SMS_GATEWAY_API_KEY=

# SMS queue tuning (optional)
SMS_QUEUE_CONCURRENCY=2
SMS_QUEUE_JOB_TIMEOUT_MS=15000
SMS_QUEUE_RETRY_ROUNDS=2
SMS_QUEUE_GATEWAY_COOLDOWN_MS=30000
