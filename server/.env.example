# MongoDB Configuration
# For MongoDB Atlas:
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/crm_db?retryWrites=true&w=majority

# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/crm_db

# JWT Secret
JWT_SECRET=your-super-secret-key-change-in-production

# Secret encryption key for storing provider credentials (WhatsApp, Email, etc.)
# Use a strong random string (32+ chars).
WHATSAPP_STORE_ENCRYPTION_KEY=change-me-32-chars-min

# Server Port
API_PORT=3000

# Public base URL of your API server (used for email tracking links/pixel)
# Example: https://neomobile.neophrondev.in
PUBLIC_BASE_URL=

# OTP SMS for signup/mobile verification
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# WhatsApp template OTP for signup flow
NEO_OTP_WHATSAPP_URL=https://aiwhatsappapi.neophrontech.com/v1/message/send-message
NEO_OTP_TEMPLATE_TOKEN=
NEO_OTP_TEMPLATE_NAME=
NEO_OTP_TEMPLATE_LANGUAGE=en
NEO_OTP_TEMPLATE_APP_NAME=NeoApp
