{
  "expo": {
    "name": "myApp",
    "slug": "myapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "output": "single",
      "bundler": "metro"
    },
    "android": {
      "package": "com.myapp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "READ_CALL_LOG",
        "READ_PHONE_STATE",
        "READ_CONTACTS",
        "ANSWER_PHONE_CALLS",
        "CALL_PHONE"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-image-picker",
      "expo-av",
      "expo-video",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24"
          }
        }
      ]
    ],
