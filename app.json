{
  "expo": {
    "name": "NeoGroww",
    "slug": "neoapp-manibro23",
    "owner": "manibro23",
    "version": "1.0.0",
    "icon": "./src/assets/app-icon.png",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mycompany.myapp",
