{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://neorenderserver-q41b.onrender.com/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://neorenderserver-q41b.onrender.com/api",
        "EXPO_PUBLIC_PLAY_STORE_SAFE_MODE": "false"
      }
    },
    "enterprise": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://neorenderserver-q41b.onrender.com/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://neorenderserver-q41b.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "companyName": "NEOPHRON TECHNOLOGIES"
      }
    }
  }
}